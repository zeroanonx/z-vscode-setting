      "max_tokens": 64,
      "presence_penalty": 1,
    },
  },
  "chat.agent.maxRequests": 500,
  "Codegeex.CompletionDelay": 0.4,
  "z-code-tools.enableDecorations": true,
  "z-code-tools.showRightBadge": true,
  "z-code-tools.autoRevealSettings": false,
  "z-code-tools.accentTheme": "lilac",
  "z-code-tools.customAccentColor": "#00f5d4",
  "z-code-tools.customAccentColors": [],

  /************************** E 目录排除  ****************************************/
